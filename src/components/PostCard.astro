---
// PostCard.astro — 首页文章列表中的单条卡片
// 接收单篇文章 entry，展示标题、日期、简介、标签
export interface Props {
  post: {
    data: {
      title: string;
      slug: string;
      date: Date;
      description?: string;
      tags: string[];
    };
  };
}

const { post } = Astro.props;
const { title, slug, date, description, tags } = post.data;
---

<article class="post-card">
  <h2 class="post-title">
    <a href={`/${slug}`}>{title}</a>
  </h2>
  <div class="meta">
    <time datetime={date.toISOString()}>
      {date.toLocaleDateString("zh-CN", {
        year: "numeric",
        month: "2-digit",
        day: "2-digit",
      })}
    </time>
    {
      tags.length > 0 && (
        <span class="tags-inline">
          {" · "}
          {tags.map((tag) => <span class="tag">#{tag} </span>)}
        </span>
      )
    }
  </div>
  {description && <p class="excerpt">{description}</p>}
</article>

<style>
  .post-card {
    margin-bottom: 2.2rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--color-border);
  }
  .post-card:last-child {
    border-bottom: none;
  }
  .post-title {
    margin-top: 0;
    margin-bottom: 0.2rem;
    font-size: 1.8rem;
  }
  .post-title a {
    color: var(--color-text);
    border-bottom: none;
  }
  .post-title a:hover {
    color: var(--color-accent);
  }
  .excerpt {
    margin-top: 0.5rem;
    color: var(--color-muted);
    font-size: 0.95rem;
  }
  .tag {
    font-size: 0.85rem;
    color: var(--color-muted);
  }
</style>
