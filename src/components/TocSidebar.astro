---
// TocSidebar.astro — MDX 标题大纲导航，含滚动监听高亮
export interface Props {
  headings: Array<{ depth: number; text: string; slug: string }>;
}

const { headings } = Astro.props;
// 只展示 h2 和 h3
const toc = headings.filter((h) => h.depth >= 2 && h.depth <= 3);
---

{
  toc.length > 0 && (
    <nav class="toc">
      <div class="toc-title">目录</div>
      <ul>
        {toc.map((h) => (
          <li class={`toc-item toc-depth-${h.depth}`}>
            <a href={`#${h.slug}`} data-toc-link={h.slug}>{h.text}</a>
          </li>
        ))}
      </ul>
    </nav>
  )
}

<script>
  // 滚动监听：高亮当前可视区域的标题
  function initTocSpy() {
    const links = document.querySelectorAll<HTMLAnchorElement>("[data-toc-link]");
    if (links.length === 0) return;

    const headingIds = Array.from(links).map((a) => a.dataset.tocLink!);
    const headingEls = headingIds
      .map((id) => document.getElementById(id))
      .filter(Boolean) as HTMLElement[];

    if (headingEls.length === 0) return;

    const observer = new IntersectionObserver(
      (entries) => {
        // 找到第一个可见的标题
        const visible = entries
          .filter((e) => e.isIntersecting)
          .sort((a, b) => a.boundingClientRect.top - b.boundingClientRect.top);

        if (visible.length > 0) {
          const id = visible[0].target.id;
          links.forEach((a) => {
            a.classList.toggle("toc-active", a.dataset.tocLink === id);
          });
        }
      },
      { rootMargin: "-80px 0px -60% 0px", threshold: 0 }
    );

    headingEls.forEach((el) => observer.observe(el));
  }

  // 页面加载和 Astro 导航完成后都初始化
  initTocSpy();
  document.addEventListener("astro:page-load", initTocSpy);
</script>

<style>
  .toc {
    margin-top: 1.2rem;
    padding-top: 0.8rem;
    border-top: 1px solid var(--color-border);
  }
  .toc-title {
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--color-muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: 0.6rem;
  }
  .toc ul {
    list-style: none;
    padding: 0;
    margin: 0;
    border-left: 1px solid var(--color-border);
  }
  .toc-item {
    line-height: 1.5;
  }
  .toc-item a {
    display: block;
    color: var(--color-muted);
    border-bottom: none;
    padding: 0.2em 0 0.2em 0.75rem;
    border-left: 2px solid transparent;
    margin-left: -1px;
    transition: color 0.15s, border-color 0.15s;
  }
  .toc-item a:hover,
  .toc-item a.toc-active {
    color: var(--color-accent);
    border-left-color: var(--color-accent);
  }
  .toc-depth-3 a {
    padding-left: 1.5rem;
    font-size: 0.85rem;
  }
</style>
