---
// [slug].astro — 文章详情页
// 根据 frontmatter 中的 slug 匹配文章，渲染 MDX 正文
import { getCollection, render } from "astro:content";
import BaseLayout from "../layouts/Base.astro";
import TocSidebar from "../components/TocSidebar.astro";

export async function getStaticPaths() {
  const posts = await getCollection("blog", ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.data.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { title, date, tags, description } = post.data;
const { Content, headings } = await render(post);

const allPublished = (
  await getCollection("blog", ({ data }) => !data.draft && !data.hidden)
).sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const recommendEnabled = post.data.recommend !== false;
const firstTag = tags.length > 0 ? tags[0] : null;
const relatedPosts =
  recommendEnabled && firstTag
    ? allPublished
        .filter(
          (p) =>
            p.data.slug !== post.data.slug &&
            p.data.tags?.includes(firstTag) &&
            p.data.date <= date,
        )
        .slice(0, 3)
    : [];
---

<BaseLayout title={title} description={description}>
  <TocSidebar headings={headings} slot="sidebar" />
  <article class="post-detail">
    <header class="post-header">
      <h1>{title}</h1>
      <div class="meta">
        <time datetime={date.toISOString()}>
          {
            date.toLocaleDateString("zh-CN", {
              year: "numeric",
              month: "2-digit",
              day: "2-digit",
            })
          }
        </time>
        {
          tags.length > 0 && (
            <span class="tags-inline">
              {" · "}
              {tags.map((tag) => (
                <span class="tag">#{tag} </span>
              ))}
            </span>
          )
        }
      </div>
    </header>

    <div class="post-body">
      <Content />
    </div>

    <footer class="post-footer">
      {
        relatedPosts.length > 0 && (
          <>
            <hr />
            <nav class="post-nav">
              <span class="related-label">相关推荐</span>
              <ul>
                {relatedPosts.map((p) => (
                  <li>
                    <a href={`/${p.data.slug}`}>{p.data.title}</a>
                  </li>
                ))}
              </ul>
            </nav>
          </>
        )
      }
    </footer>
  </article>
</BaseLayout>

<style>
  .post-detail {
    max-width: 100%;
  }
  .post-header {
    margin-bottom: 2rem;
  }
  .post-header h1 {
    margin-top: 0;
    margin-bottom: 0.2rem;
  }
  .post-body {
    word-wrap: break-word;
  }
  .post-footer {
    margin-top: 3rem;
  }
  .post-nav {
    font-size: 0.95rem;
  }
  .post-nav a {
    border-bottom: none;
  }
  .post-nav a:hover {
    border-bottom: 1px solid var(--color-accent);
  }
  .tag {
    color: var(--color-muted);
    font-size: 0.85rem;
  }
  .related-label {
    color: var(--color-muted);
    font-size: 0.85rem;
  }
  .post-nav ul {
    list-style: none;
    padding: 0;
    margin: 0.5rem 0 0;
  }
  .post-nav li {
    margin-bottom: 0.3rem;
  }
</style>
