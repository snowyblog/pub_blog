---
// Base.astro — 全站页面外壳
// 每个页面使用此布局时，内容会插入 <slot />
import "../styles/global.css";
---

<!DOCTYPE html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <!-- 页面标题 -->
    <title>{Astro.props.title ?? "Blog"}</title>
    <meta
      name="description"
      content={Astro.props.description ?? "一个极简博客"}
    />
  </head>
  <body>
    <!-- 顶部导航 -->
    <header>
      <nav>
        <a href="/" class="site-title">Blog</a>
        <div class="nav-links">
          <a href="/rss.xml">RSS</a>
        </div>
      </nav>
    </header>
    <main>
      <slot />
    </main>
  </body>
</html>

<style>
  /* 导航样式 */
  header {
    margin-bottom: 2.5rem;
  }
  nav {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .site-title {
    font-weight: 700;
    font-size: 1.1rem;
    border-bottom: none;
    color: var(--color-text);
  }
  .site-title:hover {
    color: var(--color-accent);
    border-bottom: none;
  }
  .nav-links a {
    font-size: 0.95rem;
    margin-left: 1.2rem;
  }
</style>
